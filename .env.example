# Discord bot
DISCORD_TOKEN=
COMMAND_PREFIX=8

# Upload and playback behavior
MAX_UPLOAD_SIZE_MB=10
MAX_FILENAME_LENGTH=10
AUTO_LEAVE_DELAY_MS=30000

# Storage paths. For an Unraid container, point these to the mounted data path.
SOUNDS_DIR=./sounds
SOUND_COUNTS_PATH=./config/soundCounts.json
SOUND_LOGS_PATH=./config/sound_logs.txt
TEMP_DIR=./temp

# Optional Botboard API. Omit these variables to run without the dashboard.
# When enabled, BOT_API_TOKEN must match the value configured in Botboard.
BOT_API_TOKEN=
BOT_API_PORT=3002
